<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Solo Level" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" type="image/svg+xml" href="<%= asset_path('favicon.svg') %>">
    <link rel="apple-touch-icon" href="<%= asset_path('apple-touch-icon.svg') %>">
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="retro-nav">
      <div class="nav-left">
        <%= link_to root_path, class: "retro-nav-button home-button" do %>
          <span class="button-icon">🏠</span>
          <span class="button-text">HOME</span>
        <% end %>
        <%= link_to progress_index_path, class: "retro-nav-button" do %>
          <span class="button-icon">📊</span>
          <span class="button-text">PROGRESS</span>
        <% end %>
      </div>
      
      <div class="nav-right">
        <% if current_user %>
          <span class="user-info">Level <%= current_user.level %> | <%= current_user.name || current_user.email %></span>
          <%= button_to 'LOGOUT', logout_path, method: :delete, class: 'retro-nav-button' %>
        <% else %>
          <%= button_to 'SIGN IN', '/auth/github', method: :get, class: 'retro-nav-button' %>
        <% end %>
      </div>
    </nav>

    <% if current_user %>
      <div class="retro-stats">
        <div class="stat-item">
          <span class="stat-label">LEVEL</span>
          <span class="stat-value"><%= current_user.level %></span>
        </div>
        <div class="stat-item">
          <span class="stat-label">XP</span>
          <span class="stat-value"><%= current_user.xp %></span>
        </div>
        <div class="stat-item">
          <span class="stat-label">BADGES</span>
          <span class="stat-value"><%= current_user.badges || 'None' %></span>
        </div>
        <div class="stat-item">
          <span class="stat-label">STREAK</span>
          <span class="stat-value"><%= current_user.streak || 0 %></span>
        </div>
      </div>
    <% end %>

    <main class="container mx-auto mt-28 px-5 flex">
      <%= yield %>
    </main>

    <style>
      body {
        background: #0a0a0a;
        color: #00ff00;
        font-family: 'Press Start 2P', monospace;
      }

      .retro-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 2rem;
        background: #000;
        border-bottom: 2px solid #00ff00;
        box-shadow: 0 0 20px rgba(0, 255, 0, 0.1);
        z-index: 1000;
      }

      .nav-left, .nav-right {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .retro-nav-button {
        background: #000;
        border: 2px solid #00ff00;
        color: #00ff00;
        padding: 0.5rem 1rem;
        font-family: 'Press Start 2P', monospace;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }

      .retro-nav-button:hover {
        background: #001100;
        box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
      }

      .home-button {
        font-size: 1rem;
      }

      .button-icon {
        font-size: 1.2rem;
      }

      .user-info {
        color: #00ff00;
        font-size: 0.8rem;
        margin-right: 1rem;
      }

      .retro-stats {
        position: fixed;
        top: 5rem;
        right: 2rem;
        background: #000;
        border: 2px solid #00ff00;
        padding: 1rem;
        border-radius: 4px;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        z-index: 999;
      }

      .stat-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }

      .stat-label {
        font-size: 0.7rem;
        opacity: 0.8;
      }

      .stat-value {
        font-size: 0.8rem;
        color: #00ff00;
      }

      @media (max-width: 768px) {
        .retro-nav {
          padding: 0.5rem 1rem;
        }

        .retro-nav-button {
          padding: 0.3rem 0.6rem;
          font-size: 0.6rem;
        }

        .user-info {
          display: none;
        }

        .retro-stats {
          position: static;
          margin: 1rem;
          flex-direction: row;
          flex-wrap: wrap;
          justify-content: space-around;
        }
      }
    </style>
  </body>
</html>
