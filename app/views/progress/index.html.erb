<div>
  <h1 class="font-bold text-4xl">Progress#index</h1>
  <p>Find me in app/views/progress/index.html.erb</p>
</div>

<h1>Your Progress</h1>
<ul>
  <% @progresses.each do |progress| %>
    <li>
      <h3><%= progress.topic.name %></h3>
      <p>Score: <%= progress.score %></p>
      <p>Last Attempt: <%= progress.last_attempt %></p>
      <%= link_to 'View Details', progress_path(progress), class: 'text-blue-500 hover:underline' %>
    </li>
  <% end %>
</ul>
