<div class="quiz-container" data-controller="quiz">
  <div class="quiz-header">
    <h1 class="quiz-title"><%= @topic.name %></h1>
    <div class="progress-bar">
      <div class="progress" data-quiz-target="progressBar" style="width: 0%"></div>
    </div>
  </div>

  <%= form_tag submit_quiz_path(@topic), method: :post, class: "quiz-form", 
      data: { 
        action: "submit->quiz#submitQuiz",
        topic_id: @topic.id,
        topic_name: @topic.name,
        user_level: @user_level
      } do %>
    <% @questions.each_with_index do |question, index| %>
      <div class="question-container <%= 'hidden' unless index == 0 %>" 
           data-quiz-target="question"
           data-selected-answer=""
           data-question-id="<%= question.id %>">
        
        <div class="question-header">
          <span class="question-number">Question <%= index + 1 %> of <%= @questions.size %></span>
          <span class="question-type"><%= question.question_type.titleize %></span>
          <span class="difficulty-level"><%= question.difficulty_level.titleize %></span>
        </div>

        <div class="question-content">
          <p class="question-text"><%= question.text %></p>

          <% case question.question_type %>
          <% when 'multiple_choice' %>
            <div class="options-container">
              <% question.options.each do |option| %>
                <label class="option">
                  <%= radio_button_tag "answers[#{question.id}]", option, false,
                      class: "option-input",
                      data: { action: "change->quiz#selectOption" } %>
                  <span class="option-text"><%= option %></span>
                </label>
              <% end %>
            </div>

          <% when 'debugging' %>
            <div class="code-container">
              <pre><code><%= question.metadata['code_snippet'] %></code></pre>
            </div>
            <div class="options-container">
              <% question.options.each do |option| %>
                <label class="option">
                  <%= radio_button_tag "answers[#{question.id}]", option, false,
                      class: "option-input",
                      data: { action: "change->quiz#selectOption" } %>
                  <span class="option-text"><%= option %></span>
                </label>
              <% end %>
            </div>

          <% when 'project_based' %>
            <div class="project-container">
              <div class="project-description">
                <%= question.metadata['project_description'] %>
              </div>
              <div class="options-container">
                <% question.options.each do |option| %>
                  <label class="option">
                    <%= radio_button_tag "answers[#{question.id}]", option, false,
                        class: "option-input",
                        data: { action: "change->quiz#selectOption" } %>
                    <span class="option-text"><%= option %></span>
                  </label>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <div class="question-navigation">
          <% if index > 0 %>
            <button type="button" 
                    class="nav-button prev-button"
                    data-action="click->quiz#previousQuestion">
              Previous
            </button>
          <% end %>

          <% if index < @questions.size - 1 %>
            <button type="button" 
                    class="nav-button next-button"
                    data-action="click->quiz#nextQuestion"
                    disabled>
              Next
            </button>
          <% else %>
            <button type="submit" 
                    class="nav-button submit-button"
                    data-quiz-target="submitButton"
                    disabled>
              Submit Quiz
            </button>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<style>
.quiz-container {
  max-width: 800px;
  margin: 2rem auto;
  padding: 2rem;
  background: #1a1a1a;
  border-radius: 8px;
  box-shadow: 0 0 20px rgba(0, 255, 0, 0.1);
}

.quiz-header {
  margin-bottom: 2rem;
  text-align: center;
}

.quiz-title {
  color: #00ff00;
  font-size: 2rem;
  font-weight: bold;
  margin-bottom: 1rem;
}

.progress-bar {
  width: 100%;
  height: 4px;
  background: #333;
  border-radius: 2px;
  overflow: hidden;
}

.progress {
  height: 100%;
  background: #00ff00;
  transition: width 0.3s ease;
}

.question-container {
  margin-bottom: 2rem;
}

.question-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 1rem;
  color: #888;
  font-size: 0.9rem;
}

.question-content {
  background: #222;
  padding: 1.5rem;
  border-radius: 8px;
  margin-bottom: 1.5rem;
}

.question-text {
  color: #fff;
  font-size: 1.2rem;
  margin-bottom: 1.5rem;
}

.options-container {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.option {
  display: flex;
  align-items: center;
  padding: 1rem;
  background: #333;
  border: 1px solid #444;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.option:hover {
  background: #444;
  border-color: #00ff00;
}

.option-input {
  margin-right: 1rem;
}

.option-text {
  color: #fff;
}

.question-navigation {
  display: flex;
  justify-content: space-between;
  margin-top: 2rem;
}

.nav-button {
  padding: 0.75rem 1.5rem;
  background: #333;
  color: #fff;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.nav-button:hover:not(:disabled) {
  background: #444;
}

.nav-button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Results Styles */
.quiz-results {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 2rem;
}

.quiz-results .quiz-container {
  background: #1a1a1a;
  width: 100%;
  max-width: 600px;
}

.results-content {
  padding: 2rem;
  background: #222;
  border-radius: 8px;
}

.score-display {
  text-align: center;
  margin-bottom: 2rem;
}

.score-number {
  color: #00ff00;
  font-size: 3.5rem;
  font-weight: bold;
  margin-bottom: 0.5rem;
}

.score-percentage {
  color: #888;
  font-size: 1.4rem;
}

.results-details {
  margin-bottom: 2rem;
}

.result-item {
  display: flex;
  justify-content: space-between;
  padding: 1rem;
  background: #333;
  border-radius: 6px;
  margin-bottom: 1rem;
}

.result-label {
  color: #888;
}

.result-value {
  color: #fff;
  font-weight: bold;
}

.results-actions {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.action-button {
  display: block;
  width: 100%;
  padding: 1rem;
  text-align: center;
  border-radius: 6px;
  text-decoration: none;
  font-weight: bold;
  transition: all 0.2s ease;
}

.action-button.primary {
  background: #00ff00;
  color: #000;
}

.action-button.primary:hover {
  background: #00cc00;
}

.action-button.secondary {
  background: #333;
  color: #fff;
}

.action-button.secondary:hover {
  background: #444;
}
</style>
