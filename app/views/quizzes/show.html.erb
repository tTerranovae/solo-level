<div class="quiz-container" data-controller="quiz">
  <div class="retro-header">
    <h1 class="retro-title"><%= @topic.name %> Quiz</h1>
    <div class="progress-container">
      <div class="progress-bar" data-quiz-target="progressBar"></div>
    </div>
  </div>

  <%= form_tag submit_quiz_path(@topic), method: :post, class: "quiz-form" do %>
    <% @questions.each_with_index do |question, index| %>
      <div class="question-container <%= 'hidden' unless index == 0 %>" 
           data-quiz-target="question"
           data-question-index="<%= index %>">
        
        <div class="question-header">
          <h2 class="question-number">Question <%= index + 1 %> of <%= @questions.length %></h2>
          <p class="question-text"><%= question.text %></p>
        </div>

        <div class="options-container">
          <% question.options.each do |option| %>
            <div class="option-wrapper">
              <input type="radio" 
                     name="question_<%= question.id %>" 
                     value="<%= option %>" 
                     id="question_<%= question.id %>_<%= option %>"
                     class="option-input"
                     data-action="change->quiz#selectOption">
              <label for="question_<%= question.id %>_<%= option %>" 
                     class="option-label">
                <%= option %>
              </label>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="navigation-buttons">
      <button type="button" 
              class="retro-button prev-button" 
              data-action="click->quiz#previousQuestion"
              data-quiz-target="prevButton"
              disabled>
        Previous
      </button>
      
      <button type="button" 
              class="retro-button next-button" 
              data-action="click->quiz#nextQuestion"
              data-quiz-target="nextButton">
        Next
      </button>
      
      <button type="submit" 
              class="retro-button submit-button hidden" 
              data-quiz-target="submitButton">
        Submit Quiz
      </button>
    </div>
  <% end %>
</div>

<style>
html, body {
  margin: 0;
  padding: 0;
  min-height: 100vh;
  background: #0a0a0a;
}

body {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

.quiz-container {
  width: 100%;
  max-width: 800px;
  margin: 0 auto;
  padding: 2rem;
  background: #0a0a0a;
  border: 4px solid #00ff00;
  border-radius: 8px;
  box-shadow: 0 0 20px rgba(0, 255, 0, 0.15);
  font-family: 'Press Start 2P', monospace;
  color: #00ff00;
  position: relative;
}

.retro-header {
  text-align: center;
  margin-bottom: 2rem;
  background: #000;
  padding: 1.5rem;
  border: 2px solid #00ff00;
  border-radius: 4px;
}

.retro-title {
  font-size: 2rem;
  margin-bottom: 1rem;
  text-shadow: 2px 2px 0 #000, 0 0 10px #00ff00;
  color: #00ff00;
}

.progress-container {
  width: 100%;
  height: 20px;
  background: #000;
  border: 2px solid #00ff00;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: inset 0 0 10px rgba(0, 255, 0, 0.2);
}

.progress-bar {
  width: 0%;
  height: 100%;
  background: linear-gradient(90deg, #00ff00, #00cc00);
  transition: width 0.3s ease;
  box-shadow: 0 0 10px #00ff00;
}

.question-container {
  margin-bottom: 2rem;
  background: #000;
  padding: 1.5rem;
  border: 2px solid #00ff00;
  border-radius: 4px;
}

.question-header {
  margin-bottom: 1.5rem;
}

.question-number {
  font-size: 1.2rem;
  margin-bottom: 0.5rem;
  color: #00ff00;
  text-shadow: 0 0 5px #00ff00;
}

.question-text {
  font-size: 1.1rem;
  line-height: 1.5;
  margin-bottom: 1rem;
  color: #00ff00;
}

.options-container {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.option-wrapper {
  position: relative;
}

.option-input {
  position: absolute;
  opacity: 0;
}

.option-label {
  display: block;
  padding: 1rem;
  background: #000;
  border: 2px solid #00ff00;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.2s ease;
  text-shadow: 0 0 5px #00ff00;
}

.option-label:hover {
  background: #001100;
  border-color: #00ff00;
  box-shadow: 0 0 10px #00ff00;
}

.option-input:checked + .option-label {
  background: #001100;
  border-color: #00ff00;
  box-shadow: 0 0 15px #00ff00;
}

.navigation-buttons {
  display: flex;
  justify-content: space-between;
  margin-top: 2rem;
  background: #000;
  padding: 1rem;
  border: 2px solid #00ff00;
  border-radius: 4px;
}

.retro-button {
  padding: 1rem 2rem;
  background: #000;
  border: 2px solid #00ff00;
  color: #00ff00;
  font-family: 'Press Start 2P', monospace;
  cursor: pointer;
  transition: all 0.2s ease;
  text-shadow: 0 0 5px #00ff00;
}

.retro-button:hover:not(:disabled) {
  background: #001100;
  box-shadow: 0 0 15px #00ff00;
}

.retro-button:disabled {
  opacity: 0.3;
  cursor: not-allowed;
  border-color: #003300;
  color: #003300;
}

.hidden {
  display: none;
}

@keyframes glow {
  0% { box-shadow: 0 0 5px #00ff00; }
  50% { box-shadow: 0 0 20px #00ff00; }
  100% { box-shadow: 0 0 5px #00ff00; }
}

.quiz-container {
  animation: glow 2s infinite;
}

/* Add a subtle scanline effect */
.quiz-container::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    to bottom,
    rgba(0, 255, 0, 0.03) 50%,
    rgba(0, 0, 0, 0.1) 50%
  );
  background-size: 100% 4px;
  pointer-events: none;
  z-index: 1;
}
</style>
